modules = ["web", "python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Auto-Sync"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m uvicorn server:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "GitHub Auto-Sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 auto_sync.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "-m", "uvicorn", "server:app", "--host", "0.0.0.0", "--port", "5000"]
